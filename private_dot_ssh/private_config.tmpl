{{- $machineName := .machine_name | default "" -}}
{{- $machine := index (index . "machines" | default dict) $machineName | default dict -}}
{{- $machineClass := index . "machine_class" | default (index $machine "machine_class" | default "") -}}
{{- $machineOs := index . "machine_os" | default (index $machine "os" | default .chezmoi.os) -}}
{{- $machineShellProfile := index . "machine_shell_profile" | default (index $machine "machine_shell_profile" | default "") -}}
{{- $usesForwardedSshAgent := index . "uses_forwarded_ssh_agent" | default (and (eq $machineClass "work") (eq $machineOs "linux")) -}}
Host github.com
    HostName github.com
    User git
{{- if eq $machineShellProfile "work_macos" }}
    AddKeysToAgent yes
    UseKeychain yes
    IdentityFile ~/.ssh/id_ed25519_github
{{- end }}
{{- if $usesForwardedSshAgent }}
    # GitHub auth comes from a forwarded agent. Point SSH at a stable symlink
    # so shells and tools do not depend on transient socket paths.
    IdentityAgent ~/.ssh/ssh_auth_sock
{{- end }}
{{- if eq $machineClass "personal" }}

{{ include (joinPath .chezmoi.sourceDir "dotfiles_private" "private_dot_ssh" "config.personal") }}
{{- end }}
{{- if eq $machineShellProfile "work_macos" }}

{{ include (joinPath .chezmoi.sourceDir "dotfiles_private" "private_dot_ssh" "config.work_macos") }}
{{- end }}
