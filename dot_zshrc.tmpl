# ~/.zshrc: executed by zsh(1) for interactive shells.
case $- in
    *i*) ;;
      *) return;;
esac

if [ -f "$HOME/.config/shell/shared.sh" ]; then
    . "$HOME/.config/shell/shared.sh"
fi

if [ -f "$HOME/.config/shell/aliases.sh" ]; then
    ALI_SHELL_RC="$HOME/.zshrc"
    . "$HOME/.config/shell/aliases.sh"
fi

if [ -f "$HOME/.config/zsh/prompt.zsh" ]; then
    . "$HOME/.config/zsh/prompt.zsh"
fi

{{ $taskType := index . "machine_class" | default "" -}}
# Layered shell config, loaded most-general to most-specific:
#   task -> machine -> secrets (each loads only if present).
# (Bash adds a base layer too; on macOS, zsh's shared base comes from
# ~/.config/shell/shared.sh, loaded above.)
_load_layer() { [ -f "$1" ] && . "$1"; }
{{- if $taskType }}
_load_layer "$HOME/.config/shell/task/{{ $taskType }}.sh"
{{- end }}
_load_layer "$HOME/.config/shell/machine/local.sh"
# Login shells load secrets from ~/.zprofile. Keep this fallback for shells
# started interactively without a login parent, such as some editor terminals.
if [[ ! -o login ]]; then
    _load_layer "$HOME/.config/shell/machine/local.secrets.sh"
fi
unset -f _load_layer
