# ~/.zshrc: executed by zsh(1) for interactive shells.
case $- in
    *i*) ;;
      *) return;;
esac

if [ -f "$HOME/.config/shell/shared.sh" ]; then
    . "$HOME/.config/shell/shared.sh"
fi

if [ -f "$HOME/.config/shell/aliases.sh" ]; then
    ALI_SHELL_RC="$HOME/.zshrc"
    . "$HOME/.config/shell/aliases.sh"
fi

if [ -f "$HOME/.config/zsh/prompt.zsh" ]; then
    . "$HOME/.config/zsh/prompt.zsh"
fi

{{- $machineName := .machine_name | default "" -}}
{{- $machines := index . "machines" | default dict -}}
{{- $machine := index $machines $machineName | default dict -}}
{{- $machineShellProfile := index . "machine_shell_profile" | default (index $machine "machine_shell_profile" | default "") }}
{{- if $machineShellProfile }}
if [ -f "$HOME/.config/shell/machine/{{ $machineShellProfile }}.sh" ]; then
    . "$HOME/.config/shell/machine/{{ $machineShellProfile }}.sh"
fi
{{- end }}
