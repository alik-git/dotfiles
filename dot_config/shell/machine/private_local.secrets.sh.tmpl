{{- /* Secrets layer: this machine's secrets, decrypted from the private repo
       (an age-encrypted file selected by machine_name). The public source holds
       no secret and no machine name — only the decrypt directive and the
       variable. Renders to a comment when the encrypted file or the age
       identity is absent. Target is mode 0600 via the private_ attribute. */ -}}
{{- $name := .machine_name | default "" -}}
{{- $f := joinPath .chezmoi.sourceDir "dotfiles_private" "machine_secrets" (printf "%s.secrets.sh.age" $name) -}}
{{- if and (ne $name "") (stat $f) -}}
{{ include $f | decrypt }}
{{- else -}}
# No secrets layer for this machine.
{{ end -}}
