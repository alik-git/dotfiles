{{- /* Secrets layer: shared work-class secrets plus this machine's own secrets,
       decrypted from the private repo. Two age-encrypted sources are selected by
       machine_class ("class_<class>.secrets.sh.age", shared across machines of a
       class) and machine_name ("<name>.secrets.sh.age", machine-specific). The
       public source holds no secret and no machine name — only the decrypt
       directive and the variables. Renders to a comment when neither encrypted
       file (or the age identity) is present. Target is mode 0600 via the
       private_ attribute. */ -}}
{{- $name := index . "machine_name" | default "" -}}
{{- $class := index . "machine_class" | default "" -}}
{{- $classF := joinPath .chezmoi.sourceDir "dotfiles_private" "machine_secrets" (printf "class_%s.secrets.sh.age" $class) -}}
{{- $machineF := joinPath .chezmoi.sourceDir "dotfiles_private" "machine_secrets" (printf "%s.secrets.sh.age" $name) -}}
{{- $hasClass := and (ne $class "") (stat $classF) -}}
{{- $hasMachine := and (ne $name "") (stat $machineF) -}}
{{- if $hasClass }}
{{ include $classF | decrypt -}}
{{- end }}
{{- if $hasMachine }}
{{ include $machineF | decrypt -}}
{{- end }}
{{- if not (or $hasClass $hasMachine) }}
# No secrets layer for this machine.
{{- end }}
