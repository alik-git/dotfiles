# Machine-specific shell additions for work machines.
#
# Holds both manual profile config and tool-managed init (conda, nvm, ...).
# If an installer appends init to ~/.bashrc, move it into this file instead.

# Keep interactive terminals colorful even if a parent process exported NO_COLOR.
unset NO_COLOR
export CLICOLOR=1

_work_machine_is_shpool_ssh_auth_sock() {
    case "${1:-}" in
        /run/user/*/shpool/sessions/*/ssh-auth-sock.socket) return 0 ;;
        *) return 1 ;;
    esac
}

_work_machine_is_forwarded_ssh_auth_sock() {
    case "${1:-}" in
        /tmp/ssh-*/agent.*) return 0 ;;
        *) return 1 ;;
    esac
}

_work_machine_has_ssh_auth_identity() {
    local candidate_sock="${1:-}"

    [ -S "$candidate_sock" ] || return 1
    SSH_AUTH_SOCK="$candidate_sock" ssh-add -l >/dev/null 2>&1
}

_work_machine_set_stable_ssh_auth_sock() {
    local source_sock="${1:-}"
    local stable_sock="$HOME/.ssh/ssh_auth_sock"

    [ -n "$source_sock" ] || return 1
    if [ "$source_sock" = "$stable_sock" ]; then
        _work_machine_has_ssh_auth_identity "$stable_sock" || return 1
        export SSH_AUTH_SOCK="$stable_sock"
        return 0
    fi
    _work_machine_is_shpool_ssh_auth_sock "$source_sock" && return 1
    _work_machine_is_forwarded_ssh_auth_sock "$source_sock" || return 1
    _work_machine_has_ssh_auth_identity "$source_sock" || return 1
    mkdir -p "$HOME/.ssh"
    ln -sfn "$source_sock" "$stable_sock"
    export SSH_AUTH_SOCK="$stable_sock"
}

_work_machine_find_forwarded_ssh_auth_sock() {
    local candidate_sock

    for candidate_sock in /tmp/ssh-*/agent.*; do
        _work_machine_has_ssh_auth_identity "$candidate_sock" || continue
        printf '%s\n' "$candidate_sock"
        return 0
    done
    return 1
}

_work_machine_refresh_stable_ssh_auth_sock() {
    local recovered_sock

    if [ -n "${SSH_AUTH_SOCK:-}" ] && \
        _work_machine_is_forwarded_ssh_auth_sock "$SSH_AUTH_SOCK" && \
        _work_machine_has_ssh_auth_identity "$SSH_AUTH_SOCK"; then
        _work_machine_set_stable_ssh_auth_sock "$SSH_AUTH_SOCK" && return 0
    fi
    if _work_machine_has_ssh_auth_identity "$HOME/.ssh/ssh_auth_sock"; then
        export SSH_AUTH_SOCK="$HOME/.ssh/ssh_auth_sock"
        return 0
    fi
    recovered_sock="$(_work_machine_find_forwarded_ssh_auth_sock)" || return 1
    _work_machine_set_stable_ssh_auth_sock "$recovered_sock"
}

fixssha() {
    local recovered_sock

    if _work_machine_has_ssh_auth_identity "$HOME/.ssh/ssh_auth_sock"; then
        export SSH_AUTH_SOCK="$HOME/.ssh/ssh_auth_sock"
        printf 'Using stable SSH agent socket: %s\n' "$SSH_AUTH_SOCK"
        return 0
    fi

    if [ -n "${SSH_AUTH_SOCK:-}" ] && \
        _work_machine_is_forwarded_ssh_auth_sock "$SSH_AUTH_SOCK" && \
        _work_machine_has_ssh_auth_identity "$SSH_AUTH_SOCK"; then
        _work_machine_set_stable_ssh_auth_sock "$SSH_AUTH_SOCK" || return 1
        printf 'Refreshed stable SSH agent socket from current shell: %s\n' "$SSH_AUTH_SOCK"
        return 0
    fi

    recovered_sock="$(_work_machine_find_forwarded_ssh_auth_sock)" || {
        printf 'Unable to find a live forwarded SSH agent under /tmp/ssh-*/agent.*\n' >&2
        return 1
    }
    _work_machine_set_stable_ssh_auth_sock "$recovered_sock" || return 1
    printf 'Refreshed stable SSH agent socket: %s -> %s\n' \
        "$HOME/.ssh/ssh_auth_sock" "$recovered_sock"
}

_work_machine_refresh_stable_ssh_auth_sock >/dev/null 2>&1 || true

# --- Tool-managed init (installers may append below; keep it in this file) ---

# Keep pre-commit's hook cache somewhere writable in sandboxed environments.
{{- with (index . "work_cache_home" | default "") }}
export WORK_CACHE_HOME="{{ . }}"
{{- end }}
export PRE_COMMIT_HOME="${PRE_COMMIT_HOME:-${WORK_CACHE_HOME:-${XDG_CACHE_HOME:-$HOME/.cache}}/pre-commit}"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"

# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('$HOME/miniconda3/bin/conda' 'shell.bash' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]; then
        . "$HOME/miniconda3/etc/profile.d/conda.sh"
    else
        export PATH="$HOME/miniconda3/bin:$PATH"
    fi
fi
unset __conda_setup
# <<< conda initialize <<<
