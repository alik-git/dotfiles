{
  "workbench.colorTheme": "One Dark Pro",
  "workbench.iconTheme": "material-icon-theme",

  // Theme tweaks
  // Keep Python comments green, variables light, and the status bar slightly brighter.
  "editor.tokenColorCustomizations": {
    "[*]": {
      "textMateRules": [
        {
          "scope": [
            "comment.line.number-sign.python",
            "punctuation.definition.comment.python"
          ],
          "settings": {
            "foreground": "#a1d8b7",
          }
        },
        {
          "scope": [
            "variable.other.readwrite",
          ],
          "settings": {
            "foreground": "#dfdfdf",
          }
        }
      ]
    }
  },
  "workbench.colorCustomizations": {
    "[*]": {
      "statusBar.foreground": "#d3d3d3",
      "statusBar.background": "#303f4d",
    }
  },

  // Vim behavior
  // Use jj and kk to exit insert mode, while preserving core system shortcuts.
  "vim.handleKeys": {
    "<C-c>": false, // Preserve system copy behavior
    "<C-x>": false, // Preserve system cut behavior
    "<C-v>": false, // Preserve system paste behavior
    "<C-a>": false, // Preserve select-all behavior
    "<C-f>": false, // Preserve find behavior
    "<C-z>": false, // Preserve undo behavior
    "<C-b>": false, // Preserve sidebar visibility toggle
  },
  "vim.insertModeKeyBindings": [
    {
      "before": [
        "j",
        "j"
      ],
      "after": [
        "<Esc>"
      ]
    },
    {
      "before": [
        "k",
        "k"
      ],
      "after": [
        "<Esc>"
      ]
    }
  ],
  // Override VSCodeVim's default multi-cursor gb so gd then gb jumps back like Ctrl+O.
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "g",
        "b"
      ],
      "after": [
        "<C-o>"
      ]
    }
  ],

  // Editor behavior
  "editor.wordWrap": "on",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  // Treat common chezmoi templates like their underlying file types.
  "files.associations": {
    "*.md.tmpl": "markdown",
    "*.json.tmpl": "json",
    "*.jsonc.tmpl": "jsonc",
    "*.toml.tmpl": "toml",
    "*.yaml.tmpl": "yaml",
    "*.yml.tmpl": "yaml",
    "*.sh.tmpl": "shellscript",
    "*.bash.tmpl": "shellscript",
    "*.bashrc.tmpl": "shellscript",
    "*.zsh.tmpl": "shellscript",
    "*.py.tmpl": "python",
    "*.lua.tmpl": "lua",
    "*.html.tmpl": "html",
    "*.css.tmpl": "css",
    "*.js.tmpl": "javascript",
    "*.ts.tmpl": "typescript",
    "dot_bashrc.tmpl": "shellscript",
    "private_dot_gitconfig.work.tmpl": "ini",
  },

  // Workspace trust and Python UX
  "security.workspace.trust.untrustedFiles": "open",
  "python.createEnvironment.trigger": "off",
  "python-envs.terminal.autoActivationType": "off",
  "python.terminal.activateEnvironment": false,
  "python.terminal.activateEnvInCurrentTerminal": false,
{{- if eq .chezmoi.os "darwin" }}
  "python.analysis.exclude": [
    "**/.git",
    "**/.hg",
    "**/.svn",
    "**/.venv",
    "**/venv",
    "**/.env",
    "**/env",
    "**/__pycache__",
    "**/.mypy_cache",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "**/.tox",
    "**/.nox",
    "**/node_modules",
    "**/site-packages",
    "**/dist",
    "**/build",
    "Library/**",
    "Applications/**",
    "Movies/**",
    "Music/**",
    "Pictures/**",
    "Public/**",
    ".Trash/**",
    ".cache/**",
    ".cargo/**",
    ".conda/**",
    ".docker/**",
    ".local/share/Trash/**",
    ".local/share/uv/**",
    ".npm/**",
    ".vscode/extensions/**",
  ],
  "python.analysis.indexing": true,
  "python.analysis.userFileIndexingLimit": 2000,
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/.env/**": true,
    "**/env/**": true,
    "**/__pycache__/**": true,
    "**/.mypy_cache/**": true,
    "**/.pytest_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.tox/**": true,
    "**/.nox/**": true,
    "**/node_modules/**": true,
    "**/site-packages/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "Library/**": true,
    "Applications/**": true,
    "Movies/**": true,
    "Music/**": true,
    "Pictures/**": true,
    "Public/**": true,
    ".Trash/**": true,
    ".cache/**": true,
    ".cargo/**": true,
    ".conda/**": true,
    ".docker/**": true,
    ".local/share/Trash/**": true,
    ".local/share/uv/**": true,
    ".npm/**": true,
    ".vscode/extensions/**": true,
  },
  "search.exclude": {
    "**/.git": true,
    "**/.hg": true,
    "**/.svn": true,
    "**/.venv": true,
    "**/venv": true,
    "**/.env": true,
    "**/env": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.tox": true,
    "**/.nox": true,
    "**/node_modules": true,
    "**/site-packages": true,
    "**/dist": true,
    "**/build": true,
    "Library": true,
    "Applications": true,
    "Movies": true,
    "Music": true,
    "Pictures": true,
    "Public": true,
    ".Trash": true,
    ".cache": true,
    ".cargo": true,
    ".conda": true,
    ".docker": true,
    ".local/share/Trash": true,
    ".local/share/uv": true,
    ".npm": true,
    ".vscode/extensions": true,
  },
  "claudeCode.preferredLocation": "panel",
{{- end }}

  // Workbench behavior
  "workbench.editor.wrapTabs": true,
  "editor.rulers": [
    88,
    120
  ],
  "[python]": {
    "diffEditor.ignoreTrimWhitespace": false,
    "gitlens.codeLens.symbolScopes": [
      "!Module"
    ]
  },
  "python.analysis.typeCheckingMode": "standard",
  "workbench.editorAssociations": {
    "git-rebase-todo": "default"
  },
  "git.confirmSync": false,
  "terminal.integrated.macOptionIsMeta": true,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
}
