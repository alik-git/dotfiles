# ~/.bashrc: executed by bash(1) for non-login shells.
# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

. "$HOME/.config/bash/shared.sh"
. "$HOME/.config/bash/prompt.sh"

# Only in shpool sessions, hang up background jobs on shell exit.
if [ -n "${SHPOOL_SESSION_NAME:-}" ]; then
    shopt -s huponexit
fi

# Load the Rust/Cargo environment if present so user-installed tools like
# `shpool` from `cargo install` are available in new shells.
if [ -f "$HOME/.cargo/env" ]; then
    . "$HOME/.cargo/env"
fi

if [ -f "$HOME/.config/bash/aliases.sh" ]; then
    . "$HOME/.config/bash/aliases.sh"
fi

# If this is an xterm set the title to user@host:dir
case "$TERM" in
xterm*|rxvt*)
    PS1="\[\e]0;${debian_chroot:+($debian_chroot)}\u@\h: \w\a\]$PS1"
    ;;
*)
    ;;
esac

{{ $taskType := index . "machine_class" | default "" -}}
{{ $osType := index (index .chezmoi "osRelease" | default dict) "id" | default .chezmoi.os -}}
{{ if eq .chezmoi.os "darwin" }}{{ $osType = "macos" }}{{ end -}}
# Layered shell config, loaded most-general to most-specific:
#   base -> os -> task -> machine -> secrets
# Each layer loads only if present, so a machine only creates the layers it
# needs. base/os/task are generic and public; the machine and secrets layers
# are rendered from the private repo for this machine.
_load_layer() { [ -f "$1" ] && . "$1"; }
_load_layer "$HOME/.config/bash/base.sh"
{{- if $osType }}
_load_layer "$HOME/.config/bash/os/{{ $osType }}.sh"
{{- end }}
{{- if $taskType }}
_load_layer "$HOME/.config/bash/task/{{ $taskType }}.sh"
{{- end }}
_load_layer "$HOME/.config/bash/machine/local.sh"
_load_layer "$HOME/.config/bash/machine/local.secrets.sh"
unset -f _load_layer

if command -v quick-status >/dev/null 2>&1; then
    if __quick_status_reminders_init_source="$(quick-status reminders init bash 2>/dev/null)"; then
        eval "$__quick_status_reminders_init_source"
    fi
    unset __quick_status_reminders_init_source
fi

# Installers (conda, nvm, rustup, ...) may append shell init below this line.
# Move shared init into ~/.config/bash/base.sh and machine-only init into the
# private machine layer, then run `chezmoi apply ~/.bashrc` to restore this file.
