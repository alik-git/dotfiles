{{/* Ignore Nautilus scripts unless this is a personal GUI machine with nautilus installed. */}}
{{- if or (ne $machineClass "personal") (not $hasGui) (not (lookPath "nautilus")) }}
.local/share/nautilus/scripts/**
{{- end }}
{{/* Ignore Linux VS Code user settings on non-Linux, non-personal, or non-GUI machines. */}}
{{- if or (ne $machineOs "linux") (ne $machineClass "personal") (not $hasGui) }}
.config/Code
.config/Code/**
.config/Code/User
.config/Code/User/**
.config/Code/User/settings.json
.config/Code/User/keybindings.json
{{- end }}
{{/* Ignore macOS VS Code user settings on non-macOS or non-GUI machines. */}}
{{- if or (ne $machineOs "darwin") (not $hasGui) }}
Library/Application Support/Code
Library/Application Support/Code/**
{{- end }}
{{/* Ignore shell profile files unless they match the selected profile. */}}
{{- if ne $machineShellProfile "personal_linux" }}
.config/bash/machine/personal_linux.sh
{{- end }}
{{- if ne $machineShellProfile "work_linux" }}
.config/bash/machine/work_linux.sh
.config/bash/machine/work_linux.secrets.sh
.config/bash/machine/work_linux.secrets.sh.age
.agent_files/work_linux
.agent_files/work_linux/**
.vscode-server
.vscode-server/**
{{- end }}
{{- if ne $machineShellProfile "work_macos" }}
.config/shell/machine/work_macos.sh
{{- end }}
{{/* Keep the Bluetooth audio override only on the personal Linux profile. */}}
{{- if ne $machineShellProfile "personal_linux" }}
.config/wireplumber
.config/wireplumber/**
.config/wireplumber/policy.lua.d/11-bluetooth-no-auto-hfp.lua
{{- end }}
