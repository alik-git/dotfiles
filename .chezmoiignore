{{/* This template decides whether Nautilus copy scripts should be installed on this machine. */}}
{{/* Read the selected machine name from ~/.config/chezmoi/chezmoi.toml. */}}
{{- $machineName := .machine_name | default "" }}
{{/* Load the tracked machine catalog from .chezmoidata/machines.yaml. */}}
{{- $machines := index . "machines" | default dict }}
{{/* Look up the current machine entry. */}}
{{- $machine := index $machines $machineName | default dict }}
{{/* Read the machine OS, falling back to chezmoi's detected OS. */}}
{{- $machineOs := index . "machine_os" | default (index $machine "os" | default .chezmoi.os) }}
{{/* Read the machine class, e.g. personal or work. */}}
{{- $machineClass := index . "machine_class" | default (index $machine "machine_class" | default "") }}
{{/* Read the reusable shell profile, e.g. personal_linux or work_linux. */}}
{{- $machineShellProfile := index . "machine_shell_profile" | default (index $machine "machine_shell_profile" | default "") }}
{{/* Read whether this machine should be treated as a GUI machine. */}}
{{- $hasGui := index . "has_gui" | default (index $machine "has_gui" | default false) }}
{{/* Public-only clones do not have the private companion submodule. */}}
{{- $hasPrivateRepo := stat (joinPath .chezmoi.sourceDir "dotfiles_private" "privacy" "denylist.tsv") }}
{{- if not $hasPrivateRepo }}
.codex/config.toml
.config/worklogs/config.toml
.gitconfig.work
.local/bin/jira-rest
.local/bin/jira-web-link
.local/lib/jira_rest.py
.local/lib/jira_web_link.py
.ssh/config
.config/bash/machine/work_linux.secrets.sh
.config/bash/machine/work_linux.secrets.sh.age
.agent_files/work_linux
.agent_files/work_linux/**
{{- end }}
{{/* Manage ~/.profile on work machines and macOS machines for login-shell environment. */}}
{{- if and (ne $machineClass "work") (ne $machineOs "darwin") }}
.profile
{{- end }}
{{/* zsh is currently only managed on macOS. */}}
{{- if ne $machineOs "darwin" }}
.zprofile
.zshrc
.config/zsh
.config/zsh/**
{{- end }}
{{/* Linux-only service and desktop integration. */}}
{{- if ne $machineOs "linux" }}
.config/systemd
.config/systemd/**
.config/wireplumber
.config/wireplumber/**
.local/share/nautilus
.local/share/nautilus/**
.local/share/nautilus/scripts/**
{{- end }}
{{/* Ubuntu packages fd and bat as fdfind and batcat; expose upstream names only on work machines. */}}
{{- if ne $machineClass "work" }}
.local/bin/bat
.local/bin/fd
{{- end }}
{{/* Keep the private work Git identity only on work machines. */}}
{{- if ne $machineClass "work" }}
.gitconfig.work
{{- end }}
