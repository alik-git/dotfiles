dotfiles_private/**
{{/* Machine facts come from the local config ([data] in chezmoi.toml): the one
     place chezmoi reliably loads at apply time. machine_class and has_gui are
     declared there; os_type is derived from chezmoi's built-in OS detection. */}}
{{- $machineName := index . "machine_name" | default "" }}
{{- $machineClass := index . "machine_class" | default "" }}
{{- $hasGui := index . "has_gui" | default false }}
{{- $osType := index (index .chezmoi "osRelease" | default dict) "id" | default .chezmoi.os }}
{{- if eq .chezmoi.os "darwin" }}{{- $osType = "macos" }}{{- end }}
{{/* Public-only clones have no private companion submodule. */}}
{{- $hasPrivateRepo := stat (joinPath .chezmoi.sourceDir "dotfiles_private" "privacy" "denylist.tsv") }}
{{- if not $hasPrivateRepo }}
.codex/config.toml
.config/worklogs/config.toml
.gitconfig.work
.local/bin/jira-rest
.local/bin/jira-web-link
.local/lib/jira_rest.py
.local/lib/jira_web_link.py
.ssh/config
.config/bash/machine/local.sh
.config/bash/machine/local.secrets.sh
.config/shell/machine/local.sh
.config/shell/machine/local.secrets.sh
.agent_files/local
.agent_files/local/**
{{- end }}
{{/* Manage ~/.profile on work machines and macOS machines for login-shell environment. */}}
{{- if and (ne $machineClass "work") (ne .chezmoi.os "darwin") }}
.profile
{{- end }}
{{/* zsh and the zsh-side shell layer are only managed on macOS. */}}
{{- if ne .chezmoi.os "darwin" }}
.zprofile
.zshrc
.config/zsh
.config/zsh/**
.config/shell
.config/shell/**
{{- end }}
{{/* Linux-only service and desktop integration. */}}
{{- if ne .chezmoi.os "linux" }}
.config/systemd
.config/systemd/**
.local/share/nautilus
.local/share/nautilus/**
.local/share/nautilus/scripts/**
{{- end }}
{{/* Ubuntu packages fd and bat as fdfind and batcat; expose upstream names only on work machines. */}}
{{- if ne $machineClass "work" }}
.local/bin/bat
.local/bin/fd
{{- end }}
{{/* Keep the private work Git identity only on work machines. */}}
{{- if ne $machineClass "work" }}
.gitconfig.work
{{- end }}
{{/* The work task shell layer is only for work machines. */}}
{{- if ne $machineClass "work" }}
.config/bash/task/work.sh
.config/shell/task/work.sh
{{- end }}
{{/* Per-machine agent docs are pulled from the private repo for work machines. */}}
{{- if ne $machineClass "work" }}
.agent_files/local
.agent_files/local/**
{{- end }}
{{/* The VS Code remote server dir is only relevant on the remote Linux work machine. */}}
{{- if not (and (eq $machineClass "work") (eq .chezmoi.os "linux")) }}
.vscode-server
.vscode-server/**
{{- end }}
backups
backups/**
.config/Code/User/README.md
.config/Code/User/extensions-manifest.txt
{{/* Ignore Nautilus scripts unless this is a personal GUI machine with nautilus installed. */}}
{{- if or (ne $machineClass "personal") (not $hasGui) (not (lookPath "nautilus")) }}
.local/share/nautilus/scripts/**
{{- end }}
{{/* Ignore Linux VS Code user settings on non-Linux, non-personal, or non-GUI machines. */}}
{{- if or (ne .chezmoi.os "linux") (ne $machineClass "personal") (not $hasGui) }}
.config/Code
.config/Code/**
.config/Code/User
.config/Code/User/**
.config/Code/User/settings.json
.config/Code/User/keybindings.json
{{- end }}
{{/* The ~/Library tree is macOS-only; never manage it on other OSes (avoids
     creating empty ~/Library/Application Support on Linux). On macOS, still gate
     the VS Code settings on GUI machines. */}}
{{- if ne .chezmoi.os "darwin" }}
Library
Library/**
{{- else if not $hasGui }}
Library/Application Support/Code
Library/Application Support/Code/**
{{- end }}
{{/* Keep WirePlumber (incl. the Bluetooth audio override) only on personal Linux machines. */}}
{{- if or (ne $machineClass "personal") (ne .chezmoi.os "linux") }}
.config/wireplumber
.config/wireplumber/**
.config/wireplumber/policy.lua.d/11-bluetooth-no-auto-hfp.lua
{{- end }}
