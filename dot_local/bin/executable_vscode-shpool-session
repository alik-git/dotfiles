#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  vscode-shpool-session <session-name> [--cmd <command>] [--require-on-create <tool> ...] [--task-ready-marker]

Examples:
  vscode-shpool-session side
  vscode-shpool-session codex --cmd "bash -ic 'codex resume; exec bash -i'" --require-on-create codex
EOF
}

die() {
    echo "vscode-shpool-session: $*" >&2
    exit 1
}

require_cmd() {
    local tool="$1"
    if ! command -v "$tool" >/dev/null 2>&1; then
        die "required command not found: $tool"
    fi
}

session_exists() {
    local session_name="$1"
    shpool list | awk 'NR > 1 { print $1 }' | grep -Fxq "$session_name"
}

session_name=""
session_cmd=""
emit_task_ready_marker="false"
declare -a required_on_create=()

while (($# > 0)); do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        --cmd)
            shift
            (($# > 0)) || die "--cmd requires a value"
            session_cmd="$1"
            ;;
        --require-on-create)
            shift
            (($# > 0)) || die "--require-on-create requires a value"
            required_on_create+=("$1")
            ;;
        --task-ready-marker)
            emit_task_ready_marker="true"
            ;;
        --*)
            die "unknown option: $1"
            ;;
        *)
            if [[ -n "$session_name" ]]; then
                die "unexpected argument: $1"
            fi
            session_name="$1"
            ;;
    esac
    shift
done

[[ -n "$session_name" ]] || {
    usage >&2
    exit 1
}

require_cmd shpool

if [[ "$emit_task_ready_marker" == "true" ]]; then
    echo "__VSCODE_TASK_BEGIN__:${session_name}"
    echo "__VSCODE_TASK_READY__:${session_name}"
    printf '\033[2J\033[H'
fi

if session_exists "$session_name"; then
    if ! shpool attach "$session_name"; then
        rc=$?
        echo "vscode-shpool-session: failed to attach to shpool session '$session_name'" >&2
        echo "If the session is stuck as attached elsewhere, run 'shpool detach $session_name' and try again." >&2
        exit "$rc"
    fi
    exit 0
fi

for tool in "${required_on_create[@]}"; do
    require_cmd "$tool"
done

if [[ -n "$session_cmd" ]]; then
    if ! shpool attach --cmd "$session_cmd" "$session_name"; then
        rc=$?
        echo "vscode-shpool-session: failed to create shpool session '$session_name'" >&2
        exit "$rc"
    fi
    exit 0
fi

if ! shpool attach "$session_name"; then
    rc=$?
    echo "vscode-shpool-session: failed to create shpool session '$session_name'" >&2
    exit "$rc"
fi
