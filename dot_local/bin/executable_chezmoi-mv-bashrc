#!/usr/bin/env bash

set -euo pipefail

MARKER='# === chezmoi-mv-bashrc boundary ==='
LIVE_BASHRC="$HOME/.bashrc"

chezmoi-mv-bashrc-diff || true

if [[ ! -f "$LIVE_BASHRC" ]]; then
  echo "Live bashrc not found: $LIVE_BASHRC" >&2
  exit 1
fi

CLEAN_BASHRC="$(chezmoi cat ~/.bashrc)"

if ! grep -Fqx "$MARKER" <<<"$CLEAN_BASHRC"; then
  echo "Marker not found in managed ~/.bashrc: $MARKER" >&2
  exit 1
fi

if ! grep -Fqx "$MARKER" "$LIVE_BASHRC"; then
  echo "Marker not found in live ~/.bashrc: $MARKER" >&2
  exit 1
fi

clean_marker_line="$(printf '%s\n' "$CLEAN_BASHRC" | awk -v marker="$MARKER" '$0 == marker { print NR; exit }')"
live_marker_line="$(awk -v marker="$MARKER" '$0 == marker { print NR; exit }' "$LIVE_BASHRC")"

clean_prefix="$(printf '%s\n' "$CLEAN_BASHRC" | head -n "$clean_marker_line")"
live_prefix="$(head -n "$live_marker_line" "$LIVE_BASHRC")"

if [[ "$clean_prefix" != "$live_prefix" ]]; then
  echo "Unexpected edits before the boundary detected." >&2
  echo "Review ~/.bashrc manually before using chezmoi-mv-bashrc." >&2
  exit 1
fi

clean_suffix="$(printf '%s\n' "$CLEAN_BASHRC" | tail -n +"$((clean_marker_line + 1))")"
live_suffix="$(tail -n +"$((live_marker_line + 1))" "$LIVE_BASHRC")"

if [[ "${live_suffix:0:${#clean_suffix}}" != "$clean_suffix" ]]; then
  echo "Non-append-only changes detected after the boundary." >&2
  echo "Review ~/.bashrc manually before using chezmoi-mv-bashrc." >&2
  exit 1
fi

appended="${live_suffix:${#clean_suffix}}"

if [[ -z "${appended//[$' \t\r\n']/}" ]]; then
  echo "No appended bashrc content found after the chezmoi boundary."
  exit 0
fi

machine_name="$(chezmoi execute-template '{{ .machine_name }}' | tr -d '\n')"
auto_target="~/.config/bash/machine/${machine_name}.auto.sh"
source_dir="$(chezmoi source-path)"
auto_source_path="${source_dir}/dot_config/bash/machine/${machine_name}.auto.sh"

mkdir -p "$(dirname "$auto_source_path")"
touch "$auto_source_path"

echo
read -r -p "Move appended bashrc content into ${auto_target} and restore ~/.bashrc? [y/N] " response
case "$response" in
  [Yy]|[Yy][Ee][Ss]) ;;
  *)
    echo "Aborted."
    exit 1
    ;;
esac

existing_auto="$(cat "$auto_source_path")"
if [[ "$existing_auto" == *"$appended"* ]]; then
  echo "Appended block already exists in the machine auto file; not duplicating it."
else
  if [[ -s "$auto_source_path" ]]; then
    printf '\n' >> "$auto_source_path"
  fi
  printf '%s' "$appended" >> "$auto_source_path"
  case "$appended" in
    *$'\n') ;;
    *) printf '\n' >> "$auto_source_path" ;;
  esac
fi

chezmoi apply ~/.bashrc "$auto_target"
echo "Moved appended content into ${auto_target} and restored ~/.bashrc."
